# SerpAPI (https://serpapi.com) – single API key for Google Flights
SERPAPI_API_KEY=your_serpapi_key

# Telegram Bot (https://core.telegram.org/bots#creating-a-new-bot)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=your_chat_id

# Settings
CURRENCY=USD
TIMEZONE=America/New_York
ACTIVE_START=7
ACTIVE_END=22
ALERT_THRESHOLD_PCT=3
MONTHLY_CALL_CAP=240
# Send a Telegram message on every run (not just on significant price changes)
NOTIFY_EVERY_RUN=true
# Archive every raw API response to responses.jsonl (set false to disable)
ARCHIVE_RESPONSES=true
# Prune history and archived responses older than this many days (each run)
RETENTION_DAYS=30
# Drop itineraries that connect through a US airport (matched against the
# built-in US_HUBS list in flight_monitor.py). Nonstop and non-US connections kept.
EXCLUDE_US_CONNECTIONS=false
# Enable Flask debug mode for the dashboard (app.py). Local development only —
# leave unset/false if the dashboard is ever reachable beyond localhost.
FLASK_DEBUG=false
